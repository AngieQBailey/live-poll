{
  "rules": {
    ".read": false,
    ".write": false,

    "sessions": {
      ".read": false,
      ".write": false,

      "$code": {
        ".read": "auth != null",
        ".write": "auth != null && !data.exists()",
        ".validate": "newData.hasChildren(['code', 'owner', 'questions', 'status'])",

        "code":      { ".validate": "newData.isString() && newData.val().length == 4" },
        "owner":     { ".validate": "newData.val() == auth.uid" },
        "createdAt": { ".validate": "newData.isNumber()" },

        "questions": {
          ".write": "auth != null && !data.exists()"
        },

        "status": {
          ".write": "auth != null && root.child('sessions').child($code).child('owner').val() == auth.uid",
          ".validate": "newData.isString() && newData.val().matches(/^(lobby|waiting|voting|closed|ended)$/)"
        },

        "currentQ": {
          ".write": "auth != null && root.child('sessions').child($code).child('owner').val() == auth.uid",
          ".validate": "newData.isNumber()"
        },

        "participants": {
          "$uid": {
            ".write": "auth != null && $uid == auth.uid",
            ".validate": "newData.hasChild('joined')"
          }
        },

        "votes": {
          "$q": {
            "$uid": {
              ".write": "auth != null && $uid == auth.uid && root.child('sessions').child($code).child('status').val() == 'voting'",
              ".validate": "newData.hasChildren(['value', 'timestamp']) && newData.child('value').isString() && newData.child('value').val().length < 200"
            }
          }
        }
      }
    }
  }
}
